# Meowtion .gitignore
#
# This excludes secrets and tooling noise only. Everything needed to understand and build the
# project IS tracked: source, Storage/Database rules, the Cloud Function, the dashboard, READMEs,
# and app/dashboard/static/js/firebase-config.js (the apiKey there is a PUBLIC client identifier,
# safe to commit; security is enforced by Auth + the rules, not by hiding it).
#
# NOTE: gitignore has no inline comments - a "#" only starts a comment at the start of a line.

# ---- Secrets & credentials (NEVER commit) ----
.env
.env.local
# firmware WiFi / device credentials
secrets.h
*.pem
*.key
*.p12
# Firebase / GCP service-account keys (this project uses none)
serviceAccount*.json
*-service-account*.json
# Streamlit deploy secrets (.streamlit/config.toml IS tracked)
.streamlit/secrets.toml
# .env.example files are intentionally NOT ignored - they document required config.

# ---- Firebase tooling / logs ----
.firebase/
.runtimeconfig.json
*-debug.log
firebase-debug.log
firestore-debug.log
database-debug.log

# ---- Python (Cloud Function) ----
__pycache__/
*.pyc
venv/
.venv/

# ---- Node / web tooling ----
node_modules/

# ---- Firmware build artifacts ----
# ESP-IDF + Zephyr build output, and generated sdkconfig (sdkconfig.defaults IS tracked)
build/
sdkconfig
sdkconfig.old

# ---- OS noise ----
.DS_Store
Thumbs.db
