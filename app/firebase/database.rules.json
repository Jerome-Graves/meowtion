{
  "rules": {
    "config": {
      ".write": false,
      "demoOwner": { ".read": true },
      "devAccounts": {
        "$uid": { ".read": "auth != null && auth.uid === $uid" }
      }
    },
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid || root.child('config').child('demoOwner').val() === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "devices": {
          "$token": {
            ".read":  "auth.uid === $uid || root.child('config').child('demoOwner').val() === $uid || root.child('deviceTokens').child($token).child('owner').val() === $uid",
            ".write": "auth.uid === $uid || root.child('deviceTokens').child($token).child('owner').val() === $uid"
          }
        }
      }
    },
    "deviceTokens": {
      "$token": {
        ".read":  "auth != null && data.child('owner').val() === auth.uid",
        ".write": "auth != null && ((!data.exists() && newData.child('owner').val() === auth.uid) || data.child('owner').val() === auth.uid)"
      }
    }
  }
}
